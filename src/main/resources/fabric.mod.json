{
  "schemaVersion": 1,
  "id": "moddinglib",
  "version": "${version}",
  "name": "ModdingLib",
  "description": "A fabric modding lib for all SAOMinecraft Mods & other project of TriggersStudio",
  "authors": [],
  "contact": {},
  "license": "MIT",
  "icon": "assets/moddinglib/icon.png",
  "environment": "client",
  "accessWidener": "moddinglib.accesswidener",
  "entrypoints": {
    "fabric-datagen": [
      "org.triggersstudio.moddinglib.client.ModdingLibDataGenerator"
    ],
    "client": [
      "org.triggersstudio.moddinglib.client.ModdingLibClient"
    ],
    "main": [
      "org.triggersstudio.moddinglib.ModdingLib"
    ]
  },
  "mixins": [
    "moddinglib.mixins.json",
    {
      "config": "moddinglib.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}"
  }
}
